{
  "name": "navai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:frontend": "astro dev --root frontend --host 0.0.0.0 --port 4321",
    "dev:backend": "tsx watch backend/src/server.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "astro build --root frontend",
    "build:backend": "tsc -p backend/tsconfig.json --noEmit",
    "check:backend-functions": "tsx backend/scripts/check-backend-functions.ts",
    "start": "tsx backend/src/server.ts",
    "lint": "eslint",
    "generate:module-loaders": "navai-generate-web-loaders --project-root frontend --src-root src --output-file src/ai/frontend-function-loaders.ts --export-name NAVAI_FRONTEND_FUNCTION_LOADERS",
    "predev": "npm run generate:module-loaders",
    "prebuild": "npm run generate:module-loaders",
    "pretypecheck": "npm run generate:module-loaders",
    "prelint": "npm run generate:module-loaders"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@navai/voice-backend": "^0.1.1",
    "@navai/voice-frontend": "^0.1.3",
    "@openai/agents": "^0.4.14",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "^5.14.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.575.0",
    "nodemailer": "^8.0.1",
    "ogl": "^1.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
