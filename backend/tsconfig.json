{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../frontend/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../frontend/src/**/*.ts"],
  "exclude": ["../frontend/src/components/**/*", "../frontend/src/theme/**/*"]
}
