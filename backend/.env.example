# HTTP server
PORT=3000

# CORS for split deployment (frontend in another origin)
CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,https://navai.luxisoft.com
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-NAVAI-Client-Id
CORS_EXPOSE_HEADERS=

# OpenAI backend key (recommended in production)
OPENAI_API_KEY=
OPENAI_AI_GRADING_MODEL=gpt-4o-mini

# Optional realtime defaults (@navai/voice-backend)
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_INSTRUCTIONS=You are a helpful assistant.
OPENAI_REALTIME_LANGUAGE=Spanish
OPENAI_REALTIME_VOICE_ACCENT=neutral Latin American Spanish
OPENAI_REALTIME_VOICE_TONE=friendly and professional
OPENAI_REALTIME_CLIENT_SECRET_TTL=600

# Optional hybrid speech output via ElevenLabs
NAVAI_TTS_PROVIDER=openai
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY_BOOST=
ELEVENLABS_STYLE=
ELEVENLABS_USE_SPEAKER_BOOST=

# Allow apiKey in request body even when OPENAI_API_KEY exists
# Keep false in production unless you explicitly need client-supplied keys.
NAVAI_ALLOW_FRONTEND_API_KEY=false

# NAVAI abuse protection for voice backend routes (/navai/*)
NAVAI_SECURITY_ENABLED=true
NAVAI_SECURITY_ALLOW_MISSING_ORIGIN=true
NAVAI_SECURITY_REQUIRE_BROWSER_CLIENT_ID=true
NAVAI_SECURITY_WINDOW_SECONDS=600
NAVAI_SECURITY_BLOCK_SECONDS=600
NAVAI_SECURITY_MAX_REQUESTS_PER_WINDOW=240
NAVAI_SECURITY_MAX_CLIENT_SECRETS_PER_WINDOW=10
NAVAI_SECURITY_MAX_FUNCTION_LISTS_PER_WINDOW=120
NAVAI_SECURITY_MAX_FUNCTION_EXECUTIONS_PER_WINDOW=150
NAVAI_SECURITY_MIN_CLIENT_SECRET_INTERVAL_SECONDS=8

# Backend multi-agent function discovery (CSV paths)
NAVAI_FUNCTIONS_FOLDERS=backend/src/ai
NAVAI_AGENTS_FOLDERS=main,evaluations,surveys
# Optional base dir for function loader resolution
NAVAI_FUNCTIONS_BASE_DIR=

# hCaptcha used by /api/quote and /api/hcaptcha/site-key
# Either PUBLIC_HCAPTCHA_SITE_KEY or HCAPTCHA_SITE_KEY can be used as site key.
PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SITE_KEY=
HCAPTCHA_SITE_SECRET_KEY=

# Cloudflare Stream used by public experience conversation media uploads
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Wompi used by NAVAI Plus purchases and webhooks
PUBLIC_WOMPI_WOMPI_PRODUCTION=false
PUBLIC_WOMPI_API_KEY=
PUBLIC_WOMPI_EVENT_SECRET=
PUBLIC_WOMPI_TEST_API_KEY=
PUBLIC_WOMPI_TEST_EVENT_SECRET=

# SMTP used by /api/quote
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
