# Frontend NAVAI multi-agent discovery (used by loader generation)
NAVAI_FUNCTIONS_FOLDERS=src/ai
NAVAI_AGENTS_FOLDERS=main,evaluations,surveys,public-experience
NAVAI_ROUTES_FILE=src/ai/main/routes.ts

# Backend API base URL for browser requests.
# Local split setup example: http://localhost:3000
# If empty, frontend falls back to same-origin.
PUBLIC_NAVAI_API_URL=http://localhost:3000

# Home hydration mode: "idle" (default) or "load"
PUBLIC_HOME_HYDRATION_MODE=idle

# Home animation/reveal timings in milliseconds (0-60000)
PUBLIC_ORB_AUTOPLAY_DELAY_MS=9000
PUBLIC_ORB_REVEAL_DELAY_MS=5200
PUBLIC_VOICE_PANEL_REVEAL_DELAY_MS=6500

# Optional hCaptcha site key exposed to the browser.
# This is public (not a secret).
PUBLIC_HCAPTCHA_SITE_KEY=

# Wompi checkout URLs used by NAVAI Plus
PUBLIC_WOMPI_CHECKOUT_URL=
PUBLIC_WOMPI_TEST_CHECKOUT_URL=

# Firebase public web config for Google authentication.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
