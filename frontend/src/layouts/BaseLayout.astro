---
import "@/styles/globals.css";
import { ClientRouter } from "astro:transitions";
import {
  LANGUAGE_OPTIONS,
  loadMessagesForLanguage,
  type LanguageCode,
} from "@/lib/i18n/messages";

type BaseLayoutProps = {
  title?: string;
  description?: string;
  path?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const GOOGLE_TAG_ID = "G-J5MXCLPYHB";
const GOOGLE_FONTS_STYLESHEET_URL =
  "https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Noto+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap";
const SITE_URL = "https://navai.luxisoft.com";
const SUPPORTED_LANGUAGES = LANGUAGE_OPTIONS.map((option) => option.code);

type SeoLanguageCopy = {
  docsLabel: string;
  implementationLabel: string;
  homeTagline: string;
  implementationTitle: string;
  implementationDescription: string;
  docsDescription: string;
  docsEntries: Record<string, { title: string; summary: string }>;
};

const {
  title = "NAVAI - Realtime Voice AI for UI Navigation & Function Execution",
  description = "NAVAI enables voice-first navigation and safe function execution across web and mobile apps.",
  path = "/",
  structuredData,
} = Astro.props as BaseLayoutProps;

const canonicalUrl = new URL(path, SITE_URL).toString();
const bannerUrl = new URL("/navai_banner.webp", SITE_URL).toString();
const logoUrl = new URL("/navai_logo.webp", SITE_URL).toString();
const isAnalyticsEnabled = import.meta.env.PROD;
const initialCaptchaSiteKey =
  (import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY as string | undefined) ??
  (import.meta.env.HCAPTCHA_SITE_KEY as string | undefined) ??
  "";

const THEME_INIT_SCRIPT = `
(() => {
  const KEY = "navai-theme";

  const isTheme = (value) => value === "light" || value === "dark";

  const readStoredTheme = () => {
    try {
      const stored = window.localStorage.getItem(KEY);
      return isTheme(stored) ? stored : null;
    } catch {
      return null;
    }
  };

  const readThemeFromRoot = (root) => {
    const dataTheme = root?.dataset?.theme;
    if (isTheme(dataTheme)) {
      return dataTheme;
    }
    if (root?.classList?.contains("dark")) {
      return "dark";
    }
    if (root?.classList?.contains("light")) {
      return "light";
    }
    return null;
  };

  const resolveTheme = (root) => {
    return readThemeFromRoot(root) || readStoredTheme() || "light";
  };

  const applyThemeToRoot = (root, theme) => {
    if (!root || !isTheme(theme)) return;
    root.classList.remove("dark", "light");
    root.classList.add(theme);
    root.dataset.theme = theme;
  };

  const syncCurrentDocument = () => {
    applyThemeToRoot(document.documentElement, resolveTheme(document.documentElement));
  };

  syncCurrentDocument();

  document.addEventListener("astro:before-swap", (event) => {
    const maybeNewDocument = event?.newDocument ?? event?.detail?.newDocument;
    if (!maybeNewDocument || !maybeNewDocument.documentElement) {
      return;
    }

    const currentTheme = resolveTheme(document.documentElement);
    applyThemeToRoot(maybeNewDocument.documentElement, currentTheme);
  });

  document.addEventListener("astro:page-load", syncCurrentDocument);

  try {
    const theme = resolveTheme(document.documentElement);
    window.localStorage.setItem(KEY, theme);
  } catch {}
})();
`;

const LANGUAGE_INIT_SCRIPT = `
(() => {
  try {
    const key = "navai-language";
    const allowed = ["en", "fr", "es", "pt", "zh", "ja", "ru", "ko", "hi"];
    const allowedSet = new Set(allowed);
    const stored = window.localStorage.getItem(key);
    if (stored && allowedSet.has(stored)) {
      const root = document.documentElement;
      root.lang = stored;
      root.dataset.language = stored;
      for (const code of allowed) {
        root.classList.remove("lang-" + code);
      }
      root.classList.add("lang-" + stored);
    }
  } catch {}
})();
`;

const HCAPTCHA_SITEKEY_INIT_SCRIPT = `
(() => {
  window.__NAVAI_HCAPTCHA_SITE_KEY__ = ${JSON.stringify(initialCaptchaSiteKey)};
})();
`;

const PWA_INIT_SCRIPT = `
(() => {
  if (typeof window === "undefined" || !("serviceWorker" in navigator)) {
    return;
  }

  const isProduction = ${JSON.stringify(import.meta.env.PROD)};
  const clearNavaiPwaCaches = async () => {
    if (typeof caches === "undefined") {
      return;
    }

    const cacheKeys = await caches.keys();
    await Promise.all(
      cacheKeys
        .filter((key) => key.startsWith("navai-pwa-"))
        .map((key) => caches.delete(key))
    );
  };

  if (!isProduction) {
    const cleanupDevServiceWorkers = async () => {
      try {
        const registrations = await navigator.serviceWorker.getRegistrations();
        await Promise.all(registrations.map((registration) => registration.unregister()));
        await clearNavaiPwaCaches();
      } catch {}
    };

    if (document.readyState === "complete") {
      void cleanupDevServiceWorkers();
      return;
    }

    window.addEventListener("load", () => {
      void cleanupDevServiceWorkers();
    }, { once: true });
    return;
  }

  const registerServiceWorker = () => {
    navigator.serviceWorker.register("/sw.js").catch(() => undefined);
  };

  if (document.readyState === "complete") {
    registerServiceWorker();
    return;
  }

  window.addEventListener("load", registerServiceWorker, { once: true });
})();
`;

const GOOGLE_ANALYTICS_LAZY_INIT_SCRIPT = `
(() => {
  const tagId = ${JSON.stringify(GOOGLE_TAG_ID)};
  const scriptSrc = "https://www.googletagmanager.com/gtag/js?id=" + tagId;
  let booted = false;

  const bootAnalytics = () => {
    if (booted) return;
    booted = true;

    window.dataLayer = window.dataLayer || [];
    window.gtag = function gtag(){ window.dataLayer.push(arguments); };
    window.gtag("js", new Date());

    const script = document.createElement("script");
    script.async = true;
    script.src = scriptSrc;
    script.onload = () => {
      window.gtag("config", tagId);
    };
    document.head.appendChild(script);
  };

  window.addEventListener("pointerdown", bootAnalytics, { once: true, passive: true });
  window.addEventListener("keydown", bootAnalytics, { once: true });
  window.addEventListener("scroll", bootAnalytics, { once: true, passive: true });
})();
`;

const seoCopyByLanguage = {} as Record<LanguageCode, SeoLanguageCopy>;

for (const language of SUPPORTED_LANGUAGES) {
  const messages = await loadMessagesForLanguage(language);
  const localizedDocs = messages.docsCatalog;
  const docsEntries: Record<string, { title: string; summary: string }> = {};

  for (const [slug, entry] of Object.entries(localizedDocs.entries)) {
    if (!entry) {
      continue;
    }
    docsEntries[slug] = {
      title: entry.title,
      summary: entry.summary,
    };
  }

  seoCopyByLanguage[language] = {
    docsLabel: messages.common.documentation,
    implementationLabel: messages.common.requestImplementation,
    homeTagline: messages.home.tagline,
    implementationTitle: messages.implementationPage.title,
    implementationDescription: messages.implementationPage.description,
    docsDescription: messages.docsPage.description,
    docsEntries,
  };
}

const SEO_LANGUAGE_INIT_SCRIPT = `
(() => {
  try {
    const storageKey = "navai-language";
    const allowed = ${JSON.stringify(SUPPORTED_LANGUAGES)};
    const selectedLanguage = window.localStorage.getItem(storageKey);
    if (!selectedLanguage || !allowed.includes(selectedLanguage)) {
      return;
    }

    const seoByLanguage = ${JSON.stringify(seoCopyByLanguage)};
    const seo = seoByLanguage[selectedLanguage];
    if (!seo) {
      return;
    }

    const siteUrl = ${JSON.stringify(SITE_URL)};
    const normalizePathname = (value) => {
      const trimmed = String(value || "").trim();
      if (!trimmed) return "/";
      const basePath = trimmed.split(/[?#]/, 1)[0] || "/";
      if (basePath === "/") return "/";
      return basePath.endsWith("/") ? basePath.slice(0, -1) : basePath;
    };

    const pathname = normalizePathname(window.location.pathname);
    let title = "";
    let description = "";
    let canonicalUrl = new URL(pathname, siteUrl).toString();

    if (pathname === "/") {
      title = "NAVAI | " + seo.homeTagline;
      description =
        seo.homeTagline +
        ". " +
        seo.docsLabel +
        " | " +
        seo.implementationLabel +
        ".";
      canonicalUrl = new URL("/", siteUrl).toString();
    } else if (pathname === "/request-implementation") {
      title = "NAVAI | " + seo.implementationTitle;
      description = seo.implementationDescription;
      canonicalUrl = new URL("/request-implementation", siteUrl).toString();
    } else if (pathname === "/documentation" || pathname.startsWith("/documentation/")) {
      const rawSlug =
        pathname === "/documentation" ? "home" : pathname.slice("/documentation/".length).trim() || "home";
      const docEntry = seo.docsEntries[rawSlug];
      title = docEntry ? "NAVAI | " + seo.docsLabel + ": " + docEntry.title : "NAVAI | " + seo.docsLabel;
      description = (docEntry && docEntry.summary) || seo.docsDescription;
      canonicalUrl = new URL(pathname, siteUrl).toString();
    } else {
      return;
    }

    document.title = title;

    const setMetaContent = (selector, content) => {
      const meta = document.querySelector(selector);
      if (!meta) return;
      if (meta.getAttribute("content") !== content) {
        meta.setAttribute("content", content);
      }
    };

    const setCanonicalHref = (href) => {
      const link = document.querySelector('link[rel="canonical"]');
      if (!link) return;
      if (link.getAttribute("href") !== href) {
        link.setAttribute("href", href);
      }
    };

    const bannerUrl = new URL("/navai_banner.webp", siteUrl).toString();
    const logoUrl = new URL("/navai_logo.webp", siteUrl).toString();

    setMetaContent('meta[name="description"]', description);
    setMetaContent('meta[property="og:url"]', canonicalUrl);
    setMetaContent('meta[property="og:title"]', title);
    setMetaContent('meta[property="og:description"]', description);
    setMetaContent('meta[property="og:image"]', bannerUrl);
    setMetaContent('meta[name="twitter:title"]', title);
    setMetaContent('meta[name="twitter:description"]', description);
    setMetaContent('meta[name="twitter:image"]', bannerUrl);
    setCanonicalHref(canonicalUrl);

    const navItems = [
      { name: seo.docsLabel, url: new URL("/documentation/home", siteUrl).toString() },
      { name: seo.implementationLabel, url: new URL("/request-implementation", siteUrl).toString() },
    ];

    const structuredDataEntries = [
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "NAVAI",
        url: siteUrl,
        logo: logoUrl,
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "NAVAI",
        url: siteUrl,
        inLanguage: selectedLanguage,
        description,
        publisher: {
          "@type": "Organization",
          name: "NAVAI",
          url: siteUrl,
          logo: logoUrl,
        },
        potentialAction: {
          "@type": "SearchAction",
          target: siteUrl + "/documentation/home?q={search_term_string}",
          "query-input": "required name=search_term_string",
        },
      },
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "NAVAI main sections",
        itemListElement: navItems.map((item, index) => ({
          "@type": "SiteNavigationElement",
          position: index + 1,
          name: item.name,
          url: item.url,
        })),
      },
      {
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: title,
        description,
        url: canonicalUrl,
        isPartOf: {
          "@type": "WebSite",
          name: "NAVAI",
          url: siteUrl,
        },
      },
    ];

    const structuredDataScript = document.querySelector("#navai-structured-data[data-navai-structured-data]");
    if (structuredDataScript) {
      structuredDataScript.textContent = JSON.stringify(structuredDataEntries);
    }
  } catch {}
})();
`;

const PRIMARY_NAV_ITEMS = [
  { name: "Documentación", url: new URL("/documentation/home", SITE_URL).toString() },
  { name: "Realizar implementación", url: new URL("/request-implementation", SITE_URL).toString() },
];

const defaultStructuredData: Array<Record<string, unknown>> = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "NAVAI",
    url: SITE_URL,
    logo: logoUrl,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "NAVAI",
    url: SITE_URL,
    inLanguage: "es",
    description,
    publisher: {
      "@type": "Organization",
      name: "NAVAI",
      url: SITE_URL,
      logo: logoUrl,
    },
    potentialAction: {
      "@type": "SearchAction",
      target: `${SITE_URL}/documentation/home?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "NAVAI main sections",
    itemListElement: PRIMARY_NAV_ITEMS.map((item, index) => ({
      "@type": "SiteNavigationElement",
      position: index + 1,
      name: item.name,
      url: item.url,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: canonicalUrl,
    isPartOf: {
      "@type": "WebSite",
      name: "NAVAI",
      url: SITE_URL,
    },
  },
];

const customStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const structuredDataEntries = [...defaultStructuredData, ...customStructuredData];
const structuredDataJson = JSON.stringify(structuredDataEntries);
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script is:inline set:html={THEME_INIT_SCRIPT}></script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0f0f10" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="NAVAI" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/navai_logo.webp" type="image/webp" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NAVAI" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={bannerUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={bannerUrl} />
    <script
      id="navai-structured-data"
      data-navai-structured-data
      type="application/ld+json"
      is:inline
      set:html={structuredDataJson}
    ></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={GOOGLE_FONTS_STYLESHEET_URL} media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href={GOOGLE_FONTS_STYLESHEET_URL} />
    </noscript>

    <script is:inline set:html={LANGUAGE_INIT_SCRIPT}></script>
    <script is:inline set:html={SEO_LANGUAGE_INIT_SCRIPT}></script>
    <script is:inline set:html={HCAPTCHA_SITEKEY_INIT_SCRIPT}></script>
    <script is:inline set:html={PWA_INIT_SCRIPT}></script>
    <ClientRouter />

    {
      isAnalyticsEnabled ? (
        <>
          <script is:inline set:html={GOOGLE_ANALYTICS_LAZY_INIT_SCRIPT}></script>
        </>
      ) : null
    }
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
